rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Published files: max 3 per user, up to 500 KB, XOR-encrypted content.
    match /publishedFiles/{fileId} {
      // Anyone with the raw link can view a published file.
      allow read: if true;

      // Only signed-in users can publish, and only under their own uid.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.size is int
                    && request.resource.data.size <= 500 * 1024
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.content is string;

      // Only the owner may delete their own file. No updates allowed.
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Uploaded files (used by dashboard files.js and the /raw/:id share page).
    match /files/{fileId} {
      // Anyone with the raw link can view a file.
      allow read: if true;

      // Only signed-in users can upload, and only under their own userId.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.size is int
                    && request.resource.data.size <= 500 * 1024
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.content is string;

      // Only the owner may delete their own file. No updates allowed.
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // User profile / metadata â€” self-only.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
